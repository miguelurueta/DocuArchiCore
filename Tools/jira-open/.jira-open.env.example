JIRA_BASE_URL=https://tu-org.atlassian.net
JIRA_EMAIL=tu.email@empresa.com
JIRA_API_TOKEN=tu_token_api

# Git/GitHub connection (used by opsxj:new)
GIT_REMOTE_NAME=origin
GIT_BASE_BRANCH=main
GITHUB_TOKEN=
# Optional. Leave empty to auto-detect from `git remote get-url origin`.
GITHUBREPO=

# Optional. Comma-separated names from repo catalog.
# Example: MiApp.Services,MiApp.Models
OPSXJ_IMPACT_REPOS=

# Optional. Comma-separated names from repo catalog that are read-only.
# Example: MiApp.Repository
OPSXJ_READONLY_REPOS=

# Optional. Semicolon-separated absolute paths to legacy repos used only for migration reference.
# Example: D:\legacy\repoA;D:\legacy\repoB
OPSXJ_MIGRATION_READONLY_REPO_PATHS=
